# Vector DB Provider Strategy (qdrant, chroma)
VECTOR_DB_PROVIDER=qdrant

# Embedding Provider Strategy (ollama, openai, gemini)
EMBEDDING_PROVIDER=ollama

# LLM Provider Strategy (openai, gemini, anthropic, openrouter)
LLM_PROVIDER=gemini

# Model Names for Generation (LLM)
OPENAI_LLM_MODEL=gpt-3.5-turbo
GEMINI_LLM_MODEL=gemini-2.5-flash
ANTHROPIC_LLM_MODEL=claude-3-haiku-20240307
OPENROUTER_LLM_MODEL=meta-llama/llama-3-8b-instruct

# Model Names for Embeddings
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
GEMINI_EMBEDDING_MODEL=text-embedding-004

# API Keys
OPENAI_API_KEY=********
GOOGLE_API_KEY=********
ANTHROPIC_API_KEY=********
OPENROUTER_API_KEY=********

# Configured Variables
QDRANT_URL=http://localhost:6333
DATA_DIR=./data
COLLECTION_NAME=my_rag_collection
